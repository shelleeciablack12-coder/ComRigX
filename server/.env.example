# Server Configuration

# Port the server runs on
PORT=3001

# Environment (development or production)
NODE_ENV=development

# Allowed origins for CORS (comma-separated)
# For development: http://localhost:5173,http://localhost:3000
# For production: https://yourdomain.com
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3001

# Database (future - for now using file-based persistence)
# MONGODB_URI=mongodb://localhost:27017/comrigx

# Session configuration
# Maximum session age in milliseconds (default: 30 days)
MAX_SESSION_AGE=2592000000

# JWT Secret (for future JWT implementation)
# JWT_SECRET=your-secret-key-here

# Security
# Enable HTTPS in production
ENABLE_HTTPS=false

# Logging
LOG_LEVEL=debug
